# Copy to .env and fill in real values — never commit .env

ADDR=:8080
DATABASE_URL=postgres://user:pass@host/dbname?sslmode=require
# localhost:6379 for local dev; use the k8s service name "redis:6379" in-cluster
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
LOG_LEVEL=info

# Auth0 — required in production, optional when DEV_AUTH_TOKEN is set
AUTH0_DOMAIN=your-tenant.us.auth0.com
AUTH0_AUDIENCE=https://api.playquibble.io

# Dev auth bypass — allows the frontend to call the API without a real Auth0
# token during local development. Set to any hard-to-guess string locally.
# Must be left BLANK or unset in staging and production.
DEV_AUTH_TOKEN=
